{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-apprentice.local/schemas/aicad-packaging-handoff.schema.json",
  "title": "Legacy AI Apprentice to AICAD packaging handoff",
  "description": "Deprecated compatibility schema. New integrations must use ai-apprentice-aicad-request-v1.schema.json and validate the bound result with ai-apprentice-aicad-result-v1.schema.json.",
  "$comment": "Kept for reading pre-1.0 review artifacts only; the 1.0 workflow emits transparent_ai_apprentice_aicad_request_v1.",
  "type": "object",
  "required": ["format", "sessionId", "targetPlugin", "requirements", "evidence", "truthPriority", "prohibitedInferences", "requiredValidation", "locks"],
  "properties": {
    "format": { "const": "transparent_ai_apprentice_aicad_packaging_handoff_v1" },
    "sessionId": { "type": "string", "minLength": 1 },
    "targetPlugin": { "const": "aicad-agent" },
    "requirements": { "type": "object" },
    "evidence": {
      "type": "object",
      "required": ["solutionPlan", "image2Sample", "sampleSelfCheck", "teacherMaskCorrection", "image2LocalEdit"]
    },
    "truthPriority": { "type": "array", "minItems": 4, "items": { "type": "string" } },
    "prohibitedInferences": {
      "type": "array",
      "contains": { "const": "measure_dimensions_from_image2_pixels" }
    },
    "requiredValidation": { "type": "array", "minItems": 6, "items": { "type": "string" } },
    "locks": {
      "type": "object",
      "properties": {
        "reviewOnly": { "const": true },
        "accepted": { "const": false },
        "ruleEnabled": { "const": false },
        "packagingGated": { "const": true }
      },
      "required": ["reviewOnly", "accepted", "ruleEnabled", "packagingGated"]
    }
  },
  "additionalProperties": true
}
